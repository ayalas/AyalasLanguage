{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (web)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/AyalasLanguageAPI/bin/Debug/net9.0/AyalasLanguageAPI.dll",
            "args": [],
            "cwd": "${workspaceFolder}/AyalasLanguageAPI",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "https://localhost:7010",
            "webRoot": "${workspaceFolder}/AyalasLanguageWeb",
            "userDataDir": true,
            "sourceMaps": true,
            "smartStep": true
        }
    ]
}