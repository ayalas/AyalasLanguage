{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "admin/**", "bin/**", "obj/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "cache": true,
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js"]
    }
  }
}